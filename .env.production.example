# =============================================================================
# Variáveis de ambiente — Produção Juliana Gaspar
# =============================================================================
# Copie este arquivo para .env.production e preencha os valores.
# NUNCA comite .env.production com valores reais no Git.
# =============================================================================

# ── Banco de Dados (PostgreSQL) ─────────────────────────────────────────────
# Connection string do PostgreSQL gerenciado (Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/juliana_gaspar

# ── API (NestJS) ────────────────────────────────────────────────────────────
# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-use-random-64-chars
JWT_EXPIRATION=7d

# Porta interna da API (não exposta diretamente — o nginx faz o proxy)
API_PORT=3001

# URL do frontend que pode acessar a API
CORS_ORIGIN=https://julianagaspar.com.br

# Ambiente
NODE_ENV=production

# ── Web (Next.js) — BUILD TIME ──────────────────────────────────────────────
# URL base da API. Use /api se API e Web estiverem sob o mesmo domínio com
# proxy reverso. Use a URL completa se forem deploys separados.
NEXT_PUBLIC_API_URL=/api

# ── Serviços Futuros (não implementados ainda) ──────────────────────────────
