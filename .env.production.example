# =============================================================================
# Variáveis de ambiente — Produção Juliana Gaspar (EasyPanel)
# =============================================================================
# Configure estas variáveis no EasyPanel (seção Environment do serviço).
# NUNCA comite valores reais no Git.
# =============================================================================

# ── Banco de Dados (PostgreSQL — serviço EasyPanel) ────────────────────────────
# O EasyPanel gera usuário/senha/host ao criar o serviço de banco.
# Exemplo: postgresql://usuario:senha@juliana-gaspar-db:5432/juliana_gaspar
DATABASE_URL=postgresql://user:password@host:5432/juliana_gaspar

# ── API (NestJS) ───────────────────────────────────────────────────────────────
# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-use-random-64-chars
JWT_EXPIRATION=7d

# Porta interna da API (não exposta diretamente — o nginx faz o proxy)
API_PORT=3001

# URL do frontend que pode acessar a API (deixe em branco ou preencha com a URL final)
CORS_ORIGIN=

# Ambiente
NODE_ENV=production

# ── Web (Next.js) — BUILD TIME ─────────────────────────────────────────────────
# Use /api — API e Web rodam no mesmo container com nginx como proxy reverso
NEXT_PUBLIC_API_URL=/api

# ── Serviços Futuros (não implementados ainda) ─────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
