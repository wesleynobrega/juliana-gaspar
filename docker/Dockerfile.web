FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS builder
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN pnpm turbo build --filter=@juliana-gaspar/web

FROM base AS runner
WORKDIR /app

# curl para healthcheck (BusyBox wget não suporta --spider/--no-verbose)
RUN apk add --no-cache curl

# Non-root user
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD curl -sf http://localhost:3000 || exit 1

EXPOSE 3000
ENV PORT=3000
# Next.js standalone lê HOSTNAME e escuta apenas nesse IP.
# Docker define HOSTNAME como o ID do container, quebrando o bind.
ENV HOSTNAME=0.0.0.0
USER nodejs
CMD ["node", "apps/web/server.js"]
