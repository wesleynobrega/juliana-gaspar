    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v1_responsive_rules",
      "label": "Responsive Behavior Rules v1: card vs table breakpoints, filter strategies, pagination patterns, form layout per device",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture.md",
      "source_location": "Seção 6 — Regras de Comportamento Responsivo",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Mobile: cards only, bottom sheet filters, Prev/Next pagination. Tablet: table with essential columns, drawer filters. Desktop: full table, inline filters, numbered pagination. Same core principles as v2 but less exhaustively specified."
