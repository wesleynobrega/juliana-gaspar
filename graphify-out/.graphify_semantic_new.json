    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_spec",
      "label": "Architecture Specification v2 (Production-Ready)",
      "file_type": "document",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_naming_convention",
      "label": "Bilingual Naming Convention: PT-BR for business routes/features/URLs, English for NestJS modules and technical packages",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção Convenção de Nomenclatura",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "NestJS modules align with packages/contracts and packages/database which are technical packages in English. Business URLs and features use Portuguese because the end user sees Portuguese in URLs, labels, and breadcrumbs."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_import_hierarchy",
      "label": "Import Hierarchy Rules: app → features → components/ui → lib, with strict prohibitions on cross-feature imports and server/client boundaries",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 4 — Regras de Importação",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Prevents circular dependencies, enforces separation of concerns, ensures features are self-contained, and protects server-only code from leaking to the client."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_feature_structure",
      "label": "Feature Structure Pattern: features/<scope>/<dominio>/ with components/, types/, hooks/, schemas/, services/, actions/",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 3 — Estrutura de Feature",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Every feature must have at minimum components/, types/, and an index.ts barrel export. Pages in app/ only orchestrate — zero business logic in page.tsx."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_mobile_first",
      "label": "Mobile-First Design Paradigm: 320px baseline, cards not tables, thumb-friendly zones, touch targets >= 48px",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seções 7-10",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Primary target audience is women accessing via smartphone (WhatsApp → landing page). All styles start mobile (no prefix), media queries add behavior upward (md:, lg:)."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_validation_pipeline",
      "label": "Multi-Layer Validation Pipeline: Client Zod → NestJS ZodValidationPipe → Service business rules → Prisma schema",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 5 — Estratégia de Validação",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Client validates forms before sending. Next.js proxy does NOT validate — it only forwards. NestJS controller uses ZodValidationPipe with contracts/. Service adds business rules. Prisma validates schema."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_proxy_pattern",
      "label": "Next.js API Proxy Pattern: app/api/[...route]/route.ts forwards requests to NestJS, never validates, never accesses DB",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 6 — Proxy app/api/",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Next.js handles routing, SSR, and auth cookies on the front. NestJS runs on a separate port. In dev, Next.js proxies to NestJS. In production, Nginx/reverse proxy can bypass the Next.js proxy."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_single_source_schemas",
      "label": "Single Source of Truth for Zod Schemas: packages/contracts/ is the sole source; NestJS DTOs re-export, never duplicate",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 14 — Alinhamento Backend ↔ Contracts",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Contracts define the exact API contract shape. NestJS must never redefine schemas — it re-exports from contracts. Feature-local schemas are only for UI-specific forms (wizards, confirm-password)."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_ui_states",
      "label": "Mandatory UI States: Loading (skeleton), Empty with CTA, Error with retry, Success toast, Disabled visual",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 10 — Estados de UI Obrigatórios",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Every list component must implement all five states. Loading uses skeletons matching content structure, never 'Carregando...' text. Empty states include contextual CTAs."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_touch_targets",
      "label": "Touch Target Specifications: buttons 48px min, card area 88px min, floating action 56px, thumb-friendly zones",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 9 — Touch Targets e Zonas de Toque",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "WCAG 2.2 Level AA compliance. Primary actions must be in the bottom half of the screen (thumb-friendly zone). Destructive actions must never be the easiest to reach."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_card_vs_table",
      "label": "Card vs Table Pattern: cards mandatory below 768px, table allowed at tablet+, full table at desktop",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 8.1 — Listagens",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Tables are NEVER the primary experience for transactional data on mobile. Horizontal scroll for data is prohibited. Cards must be entirely tappable with min-height 88px."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_filter_pattern",
      "label": "Filter Pattern by Breakpoint: bottom sheet on mobile, drawer on tablet, inline bar on desktop",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 8.3 — Filtros por breakpoint",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Mobile uses Sheet with 85vh max from bottom. Tablet uses Drawer 400px from right. Desktop uses inline horizontal bar. Active filter count shown as badge on filter button."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_pagination_pattern",
      "label": "Pagination Pattern: Prev/Next large buttons on mobile, numbered pages on tablet+",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 8.4 — Paginação",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Mobile shows 'Page X of Y' between Prev/Next buttons at 48px height. First page disables (never hides) Prev. Last page disables Next. Loading between pages shows skeleton."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_navigation_pattern",
      "label": "Admin Navigation by Breakpoint: drawer from left on mobile, 64px icon sidebar on tablet, 240px fixed sidebar on desktop",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 11 — Navegação Admin",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Mobile: 56px fixed header with hamburger, drawer overlay from left with swipe-to-close. Tablet: 64px collapsed icons expandable to 240px. Desktop: 240px fixed sidebar with icons + labels + section groups."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_dashboard_pattern",
      "label": "Dashboard Layout by Breakpoint: 2 KPI columns mobile, 3 tablet, 4 desktop; graphs 200px mobile, 350px desktop",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 12 — Dashboards por Breakpoint",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "KPIs prioritized on mobile: revenue, active orders, pending orders, pending payments. Pie charts prohibited on mobile (illegible). Horizontal bar charts preferred. Tooltips must work with touch."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_form_multistep",
      "label": "Multi-Step Form Pattern: mandatory for 5+ fields on mobile, max 5 fields per step, sticky continue/back buttons",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 13 — Formulários por Breakpoint",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Labels always above inputs (never inline). All inputs min 48px height. Inline validation below fields. Submit button full-width sticky on mobile, auto-width inline on desktop."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_antipatterns",
      "label": "Prohibited Anti-Patterns: feature cross-imports, app/ business logic, duplicated Zod schemas, hover-only actions, horizontal data scroll",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 15.4 — Anti-padrões PROIBIDOS",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "10 strict prohibitions enforced by code review: no feature-to-feature imports, no business logic in page.tsx, no domain knowledge in components/ui/, no duplicated schemas, no hover-only reveals, no horizontal data scroll."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_governance",
      "label": "Architecture Governance: feature creation checklist, shared extraction rules, minimum feature requirements",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 15 — Governança de Arquitetura",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "New features follow 6-step process. Every feature must have components/, types/, index.ts. Shared code extraction rules: visual → components/ui/, logic → lib/, API types → packages/contracts/."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_definition_of_done",
      "label": "Definition of Done: 16-point checklist covering responsive breakpoints, UI states, accessibility, validation, and semantic HTML",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 17 — Definition of Done",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Every feature must work at 6 breakpoints (320px-1440px), use cards below 768px, implement all UI states, pass WCAG AA contrast, support keyboard navigation, and use semantic HTML."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_qa_checklist",
      "label": "QA Checklist: 15-item mobile validation checklist tested on real device or DevTools at 320px and 375px",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Seção 18 — QA Checklist Mobile",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Validates no horizontal scroll, critical content visible without scroll, all buttons >= 48px, touch testing, skeleton loading, empty/error states, filter sheet, pagination, destructive confirmation dialog."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_glossary",
      "label": "PT-BR to EN Terminology Glossary: Pedido→Order, Prato→Dish, Cliente→Customer, Ciclo→WeeklyCycle, Assinatura→Subscription",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Apêndice B — Glossário de Termos",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "UI uses Portuguese for user-facing text. Code uses English for technical symbols (NestJS modules, Prisma models, contracts). This glossary formalizes the mapping between the two."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v2_breakpoints",
      "label": "Tailwind Breakpoints: sm=640px, md=768px, lg=1024px, xl=1280px, 2xl=1536px",
      "file_type": "rationale",
      "source_file": "docs/superpowers/specs/2026-06-16-juliana-gaspar-architecture-v2.md",
      "source_location": "Apêndice A — Breakpoints Tailwind",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "All styles start mobile (no prefix). Media queries add behavior upward only (md:, lg:). Desktop-first CSS with mobile overrides via max-width is prohibited."
    },
    {
      "id": "specs_2026_06_16_juliana_gaspar_architecture_v1_spec",
      "label": "Architecture Specification v1 (Implementation-Ready)",
