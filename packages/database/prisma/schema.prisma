generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────

enum NutrientType {
  PROTEINA
  CARBOIDRATO
  FIBRA
  GORDURA
}

enum MealType {
  ALMOCO
  JANTA
  ALMOCO_JANTA
}

// ── Models ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id                  String    @id @default(uuid())
  name                String
  phone               String    @unique
  email               String?
  address             String?
  street              String?
  number              String?
  neighborhood        String?
  city                String?
  zipCode             String?
  instagram           String?
  whatsapp            String?
  dietaryRestrictions String?
  preferences         String?
  lgpdConsent         Boolean   @default(false)
  tags                String[]  @default([])
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders             Order[]
  subscriptions      Subscription[]
  nutritionistPlans  NutritionistPlan[]
  waitlistEntries    WaitlistEntry[]
  specialRequests    SpecialRequest[]
  favoriteMeals      FavoriteMeal[]
}

model Dish {
  id          String   @id @default(uuid())
  name        String
  description String
  photoUrl    String?
  ingredients String
  allergens   String?
  price       Float
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
  cycleDishes CycleDish[]
  recipeItems RecipeItem[]
}

model WeeklyCycle {
  id           String   @id @default(uuid())
  openDate     DateTime
  closeDate    DateTime
  deliveryDate DateTime
  status       String   @default("UPCOMING")
  maxClients   Int      @default(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders      Order[]
  cycleDishes CycleDish[]
  waitlist    WaitlistEntry[]
}

model CycleDish {
  id      String @id @default(uuid())
  cycleId String
  dishId  String

  cycle WeeklyCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  dish  Dish        @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([cycleId, dishId])
}

model Order {
  id              String    @id @default(uuid())
  customerId      String
  cycleId         String?
  planType        String    @default("SINGLE")
  status          String    @default("PENDING")
  paymentStatus   String    @default("PENDING")
  totalAmount     Float
  deliveryAddress String
  deliveryDate    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mealType          MealType          @default(ALMOCO_JANTA)
  nutritionistPlanId String?
  sourcePdfUrl       String?
  deliveryZoneId     String?

  customer          Customer          @relation(fields: [customerId], references: [id])
  cycle             WeeklyCycle?      @relation(fields: [cycleId], references: [id])
  nutritionistPlan  NutritionistPlan? @relation(fields: [nutritionistPlanId], references: [id])
  deliveryZone      DeliveryZone?     @relation(fields: [deliveryZoneId], references: [id])
  items             OrderItem[]
  meals             Meal[]
  payments          Payment[]
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  dishId    String
  quantity  Int
  unitPrice Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish  Dish  @relation(fields: [dishId], references: [id])
}

model Payment {
  id           String    @id @default(uuid())
  orderId      String
  method       String
  status       String    @default("PENDING")
  amount       Float
  paidAt       DateTime?
  refundReason String?
  refundedAt   DateTime?
  createdAt    DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Subscription {
  id          String    @id @default(uuid())
  customerId  String
  planType    String
  status      String    @default("ACTIVE")
  startDate   DateTime  @default(now())
  nextRenewal DateTime
  pausedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

model Ingredient {
  id        String   @id @default(uuid())
  name      String
  unit      String
  stockQty  Float    @default(0)
  minStock  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipeItems               RecipeItem[]
  technicalSheetIngredients TechnicalSheetIngredient[]
}

model RecipeItem {
  id           String @id @default(uuid())
  dishId       String
  ingredientId String
  quantity     Float

  dish       Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([dishId, ingredientId])
}

model DeliveryZone {
  id          String  @id @default(uuid())
  name        String
  fee         Float   @default(0)
  description String?

  orders Order[]
}

// ══════════════════════════════════════════════════════════
// v2.0 — Cardápio por Componentes Nutricionais
// ══════════════════════════════════════════════════════════

model MenuItem {
  id           String      @id @default(uuid())
  name         String
  description  String?
  nutrientType NutrientType
  photoUrl     String?
  allergens    String?
  baseUnit     String      @default("porção")
  available    Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  technicalSheet      TechnicalSheet?
  orderComponents     OrderComponent[]
  favoriteAsProtein   FavoriteMeal[] @relation("FavoriteProtein")
  favoriteAsCarbo     FavoriteMeal[] @relation("FavoriteCarbo")
  favoriteAsFiber     FavoriteMeal[] @relation("FavoriteFiber")
  favoriteAsFat       FavoriteMeal[] @relation("FavoriteFat")
}

model TechnicalSheet {
  id                 String   @id @default(uuid())
  menuItemId         String   @unique
  preparationMethod  String
  cookingTime        Int      // minutos
  temperature        String?  // ex: "200°C"
  equipment          String[]
  notes              String?
  price              Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  menuItem    MenuItem                     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients TechnicalSheetIngredient[]
}

model TechnicalSheetIngredient {
  id               String @id @default(uuid())
  technicalSheetId String
  ingredientId     String
  quantity         Float

  technicalSheet TechnicalSheet @relation(fields: [technicalSheetId], references: [id], onDelete: Cascade)
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([technicalSheetId, ingredientId])
}

model Meal {
  id      String  @id @default(uuid())
  orderId String
  notes   String?

  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  components OrderComponent[]
}

model OrderComponent {
  id         String @id @default(uuid())
  mealId     String
  menuItemId String
  quantity   Float
  unitPrice  Float

  meal     Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model NutritionistPlan {
  id            String   @id @default(uuid())
  customerId    String
  sourcePdfUrl  String
  parsedData    Json?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]
}

enum SpecialRequestStatus {
  PENDING
  FULFILLED
}

model SpecialRequest {
  id           String               @id @default(uuid())
  customerId   String?
  description  String
  nutrientType NutrientType?
  status       SpecialRequestStatus @default(PENDING)
  createdAt    DateTime             @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
}

model WaitlistEntry {
  id         String  @id @default(uuid())
  customerId String
  cycleId    String
  position   Int
  status     String  @default("WAITING") // WAITING | NOTIFIED | CONVERTED | CANCELLED
  createdAt  DateTime @default(now())

  customer Customer     @relation(fields: [customerId], references: [id])
  cycle    WeeklyCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, customerId])
}

// ══════════════════════════════════════════════════════════
// v2.1 — Favoritos e reutilização de refeições
// ══════════════════════════════════════════════════════════

model FavoriteMeal {
  id         String   @id @default(uuid())
  customerId String
  label      String   @default("Favorito")
  proteinId  String
  carboId    String
  fiberId    String
  fatId      String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  protein  MenuItem @relation("FavoriteProtein", fields: [proteinId], references: [id])
  carbo    MenuItem @relation("FavoriteCarbo", fields: [carboId], references: [id])
  fiber    MenuItem @relation("FavoriteFiber", fields: [fiberId], references: [id])
  fat      MenuItem? @relation("FavoriteFat", fields: [fatId], references: [id])
}
