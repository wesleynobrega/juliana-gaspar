{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@juliana-gaspar/contracts#build", "@juliana-gaspar/database#build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["@juliana-gaspar/contracts#build", "@juliana-gaspar/database#build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["db:migrate"]
    }
  }
}
